# --- App URL ---
AUTH_URL=http://localhost:4000

# --- Clerk Auth (email sign-in) ---
# From Clerk dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Postgres (Neon or Vercel Postgres) ---
# Set DATABASE_URL in .env.local (never commit secrets). Examples:
#
# Neon (recommended for Vercel):
#   1. Open https://console.neon.tech and create a project (or use an existing one).
#   2. Dashboard → Connection details → copy the URI (use the "pooled" string for serverless).
#   3. Ensure sslmode=require is present (Neon URLs usually include it).
# Example shape:
#   DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# Vercel Postgres:
#   1. https://vercel.com/dashboard → your project → Storage → Create Database → Postgres.
#   2. Connect the database to the project; copy POSTGRES_URL from the integration / env snippet.
#
# Optional local Postgres (Docker): from repo root run `docker compose up -d`, then:
#   DATABASE_URL=postgresql://align:align@localhost:54332/align
DATABASE_URL=

# --- Dexcom OAuth ---
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# --- Strava OAuth ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Patterns (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Apple Shortcuts → hourly steps ingest ---
# Shared secret sent as Authorization: Bearer … or X-Shortcut-Secret (match app code)
STEPS_INGEST_SECRET=

# --- Vercel Cron (protect /api/cron/* routes) ---
CRON_SECRET=

# --- Optional: encrypt OAuth refresh tokens at rest ---
TOKEN_ENCRYPTION_KEY=
