# --- App URL ---
AUTH_URL=http://localhost:4000

# --- Clerk Auth (email sign-in) ---
# From Clerk dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Postgres (Neon or Vercel Postgres) ---
# Set DATABASE_URL in .env.local (never commit secrets). Examples:
#
# Neon (recommended for Vercel):
#   1. Open https://console.neon.tech and create a project (or use an existing one).
#   2. Dashboard → Connection details → copy the URI (use the "pooled" string for serverless).
#   3. Ensure sslmode=require is present (Neon URLs usually include it).
# Example shape:
#   DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# Vercel Postgres:
#   1. https://vercel.com/dashboard → your project → Storage → Create Database → Postgres.
#   2. Connect the database to the project; copy POSTGRES_URL from the integration / env snippet.
#
# Optional local Postgres (Docker): from repo root run `docker compose up -d`, then:
#   DATABASE_URL=postgresql://align:align@localhost:54332/align
DATABASE_URL=

# --- Dexcom (pick one) ---
#
# Option A — OAuth (recommended for production): developer app + Connect in Settings
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
#
# Option B — Dexcom Share / PyDexcom-style (single CGM account on this server; anyone who
# clicks Sync imports into their Align user — fine for solo dev, bad for multi-tenant)
# PYDEXCOM_USERNAME=
# PYDEXCOM_PASSWORD=
# PYDEXCOM_REGION=us
#   us = United States (share2.dexcom.com)
#   ous = outside US (shareous1.dexcom.com); legacy alias: eu
#   jp = Japan (share.dexcom.jp)
#
# When PYDEXCOM_* is set, sync uses Share and ignores OAuth tokens for that route.
#
# Optional: official pydexcom (Python) for Share sync — `pip install pydexcom`, then sync
# prefers `scripts/fetch_dexcom_pydexcom.py` when it returns EGVs; falls back to HTTPS Share.
# PYTHON_BIN=/path/to/venv/bin/python

# Optional OAuth overrides (defaults match production api.dexcom.com; sandbox below if testing):
# DEXCOM_AUTHORIZE_URL=https://api.dexcom.com/v2/oauth2/login
# DEXCOM_TOKEN_URL=https://api.dexcom.com/v2/oauth2/token
# DEXCOM_REDIRECT_URI=http://localhost:4000/api/integrations/dexcom/callback
# DEXCOM_API_BASE_URL=https://api.dexcom.com
# DEXCOM_EGVS_URL=https://api.dexcom.com/v3/users/self/egvs
# Sandbox (separate OAuth app in Dexcom Developer):
# DEXCOM_AUTHORIZE_URL=https://sandbox-api.dexcom.com/v2/oauth2/login
# DEXCOM_TOKEN_URL=https://sandbox-api.dexcom.com/v2/oauth2/token
# DEXCOM_API_BASE_URL=https://sandbox-api.dexcom.com
# DEXCOM_STATE_SECRET=use-a-random-long-secret

# --- Strava OAuth ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Optional overrides:
# STRAVA_AUTHORIZE_URL=https://www.strava.com/oauth/authorize
# STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
# STRAVA_API_BASE_URL=https://www.strava.com/api/v3
# STRAVA_REDIRECT_URI=http://localhost:4000/api/integrations/strava/callback
# STRAVA_SCOPE=activity:read_all
# STRAVA_STATE_SECRET=use-a-random-long-secret
# Rolling window (days) for activity sync — default 30. Strava API uses epoch after/before bounds.
# STRAVA_SYNC_LOOKBACK_DAYS=30

# --- Patterns (Anthropic) — https://console.anthropic.com/ (API keys) ---
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Apple Shortcuts → hourly steps ingest ---
# Shared secret: Shortcuts header X-Shortcut-Secret (or Authorization: Bearer) must match
# the first non-empty of: STEPS_INGEST_SECRET, STEPS_TOKEN_SECRET, AUTH_SECRET
STEPS_INGEST_SECRET=
# Secret used to sign :stepIngestToken URLs (optional fallback to STEPS_INGEST_SECRET/AUTH_SECRET)
# STEPS_TOKEN_SECRET=use-a-random-long-secret

# Internal API — POST /api/ingest/steps (JSON { steps, timestamp }) with Authorization: Bearer …
INTERNAL_API_SECRET=

# Local hourly steps file on the Mac that runs Next.js (not on Vercel unless the path exists).
# POST /api/integrations/steps/import-file and /api/import/health-sync both look here.
#
# You may set either or both (they are tried in order until a file opens):
# - ICLOUD_STEPS_JSON_PATH — historically "JSON" but may also be Shortcuts `Timestamp, Steps.txt` (CSV).
# - SHORTCUTS_STEPS_FILE_PATH — Shortcuts iCloud file (same CSV format).
#
# Examples:
# ICLOUD_STEPS_JSON_PATH=/Users/you/Library/Mobile Documents/iCloud~is~workflow~my~workflows/Documents/Timestamp, Steps.txt
# ICLOUD_STEPS_JSON_PATH=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/Align/steps.json
ICLOUD_STEPS_JSON_PATH=

# Shortcuts → iCloud CSV (optional if ICLOUD_STEPS_JSON_PATH already points at Timestamp, Steps.txt).
# Default search when neither env is set:
#   …/iCloud~is~workflow~my~workflows/Shortcuts/Timestamp, Steps.txt
#   …/iCloud~is~workflow~my~workflows/Documents/Timestamp, Steps.txt
# SHORTCUTS_STEPS_FILE_PATH=

# IANA timezone for interpreting each line of Timestamp, Steps.txt (match your iPhone / Shortcut).
# Defaults to America/Los_Angeles. If the app day view uses a different zone (e.g. America/New_York),
# set this the same or May 2 in the UI won’t match buckets written from the file.
# SHORTCUTS_STEPS_TIME_ZONE=America/Los_Angeles

# --- Class / investor demo (optional) ---
# Banner in the app shell when true. Seed correlated sample data for your Clerk user:
#   DEMO_USER_ID=user_xxx npm run seed:demo
# Optional: DEMO_TIME_ZONE (default America/Los_Angeles), DEMO_DAYS (default 21, max 90).
# DEMO_MODE=true
# DEMO_USER_ID=
#
# Settings → Developer (reset manual, per-account demo banner) is on in NODE_ENV=development.
# In production, set to expose that section + matching API routes:
# ENABLE_DEVELOPER_SETTINGS=true

# --- Vercel Cron (protect /api/cron/* routes) ---
# Required for GET /api/cron/sync-integrations. Vercel sends Authorization: Bearer $CRON_SECRET
# when this env var is set on the project.
CRON_SECRET=
#
# Hourly sync (vercel.json): Dexcom OAuth (all dexcom_tokens), Strava (all strava_tokens).
# Dexcom Share (PYDEXCOM_*): fan-out to CRON_DEXCOM_SHARE_USER_IDS or any user_id that already
# has glucose_readings with source=dexcom.
# CRON_DEXCOM_SHARE_USER_IDS=user_xxx,user_yyy
#
# Optional: pull Shortcuts steps file from disk into one Align user (only useful when the server
# can read ICLOUD_STEPS_JSON_PATH / SHORTCUTS_STEPS_FILE_PATH — e.g. local or single-tenant VM).
# CRON_SYNC_SHORTCUTS_FILE=true
# CRON_SHORTCUTS_FILE_USER_ID=user_xxx
#
# Local / external scheduler:
#   curl -sS -H "Authorization: Bearer $CRON_SECRET" "https://your-host/api/cron/sync-integrations"

# --- Optional: encrypt OAuth refresh tokens at rest ---
TOKEN_ENCRYPTION_KEY=
