# Vercel environment variable template (NO SECRET VALUES).
#
# Paste into Vercel manually, or run locally:
#   npm run env:vercel-only-import
# → writes gitignored `vercel.env.vercel-only.import` from `.env.local` (never commit filled files).
#
# Notes:
# - Do not commit real secrets. Keep production values in Vercel only.
# - `NEXT_PUBLIC_*` vars are exposed to the browser bundle.
# - Local filesystem paths + the Shortcuts auto-sync scheduler are not meaningful on Vercel serverless.

# --- Core (typical production minimum) ---
AUTH_URL=
DATABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Shared secret used by multiple OAuth state + ingest fallbacks (recommended)
AUTH_SECRET=

# --- Anthropic (patterns / LLM features) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Dexcom OAuth ---
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_STATE_SECRET=
DEXCOM_AUTHORIZE_URL=
DEXCOM_TOKEN_URL=
DEXCOM_REDIRECT_URI=
DEXCOM_API_BASE_URL=
DEXCOM_DATA_BASE_URL=
DEXCOM_EGVS_URL=
DEXCOM_SCOPE=

# --- Strava OAuth ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_STATE_SECRET=
STRAVA_AUTHORIZE_URL=
STRAVA_TOKEN_URL=
STRAVA_REDIRECT_URI=
STRAVA_API_BASE_URL=
STRAVA_SCOPE=
STRAVA_SYNC_LOOKBACK_DAYS=

# --- Apple Shortcuts HTTP ingest (hosted) ---
STEPS_INGEST_SECRET=
STEPS_TOKEN_SECRET=
INTERNAL_API_SECRET=

# --- Vercel Cron auth (see vercel.json) ---
CRON_SECRET=
CRON_DEXCOM_SHARE_USER_IDS=
CRON_SYNC_SHORTCUTS_FILE=
CRON_SHORTCUTS_FILE_USER_ID=

# --- Dexcom Share / PyDexcom path (usually NOT for multi-tenant production) ---
PYDEXCOM_USERNAME=
PYDEXCOM_PASSWORD=
PYDEXCOM_REGION=
PYTHON_BIN=

# --- Demo / developer toggles ---
DEMO_MODE=
DEMO_USER_ID=
DEMO_TIME_ZONE=
DEMO_DAYS=
ENABLE_DEVELOPER_SETTINGS=
DEMO_MODE_SELF_SERVE_USER_IDS=

# --- Optional token encryption at rest ---
TOKEN_ENCRYPTION_KEY=

# --- Local Shortcuts file parsing (usually local dev only) ---
SHORTCUTS_STEPS_TIME_ZONE=
ICLOUD_STEPS_JSON_PATH=
SHORTCUTS_STEPS_FILE_PATH=

# --- Local scheduler (Next dev / long-running Node host; skipped on Vercel) ---
SHORTCUTS_AUTO_SYNC_ENABLED=
SHORTCUTS_AUTO_SYNC_USER_ID=
SHORTCUTS_AUTO_SYNC_RUN_ON_STARTUP=
